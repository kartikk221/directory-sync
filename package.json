{
    "name": "directory-sync",
    "version": "3.0.3",
    "description": "Easily synchronize directories between two machines over the internet.",
    "main": "index.js",
    "types": "index.d.ts",
    "type": "module",
    "scripts": {
        "test": "npm run test:types && node --test --test-concurrency=1 --test-timeout=30000 test/*.test.js",
        "test:types": "tsc --noEmit --strict --target ES2022 --module NodeNext --moduleResolution NodeNext --skipLibCheck test/types.test.ts",
        "test:coverage": "npm run test:types && node --test --test-concurrency=1 --experimental-test-coverage --test-coverage-lines=90 --test-coverage-functions=78 --test-coverage-branches=74 --test-timeout=30000 test/*.test.js",
        "benchmark": "node test/stress.js"
    },
    "engines": {
        "node": ">=22 <23 || >=24 <25 || >=26 <27"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/kartikk221/directory-sync.git"
    },
    "keywords": [
        "sync",
        "directory",
        "directory-sync",
        "simple-to-use",
        "sub-directory",
        "recursive"
    ],
    "author": "kartikk221",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/kartikk221/directory-sync/issues"
    },
    "homepage": "https://github.com/kartikk221/directory-sync#readme",
    "dependencies": {
        "chokidar": "^5.0.0",
        "hyper-express": "^7.0.0",
        "ws": "^8.5.0"
    },
    "devDependencies": {
        "typescript": "^5.9.3"
    }
}
